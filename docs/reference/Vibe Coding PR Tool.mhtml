<hr data-start=3D"4486" data-end=3D"4489">
<h2 data-start=3D"4491" data-end=3D"4533">Two quick decisions you should lo=
ck now</h2>
<ol data-start=3D"4534" data-end=3D"4828">
<li data-start=3D"4534" data-end=3D"4650">
<p data-start=3D"4537" data-end=3D"4650"><strong data-start=3D"4537" data-e=
