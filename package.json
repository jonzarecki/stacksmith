{
  "name": "stacksmith",
  "version": "0.1.0",
  "description": "CLI tool that splits large AI-generated diffs into clean, ordered stacks of reviewable PRs",
  "type": "module",
  "bin": {
    "stacksmith": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "demo": "bash demo/demo.sh",
    "demo:replay": "bash demo/demo.sh --replay",
    "demo:record": "vhs demo/record.tape"
  },
  "keywords": [
    "git",
    "github",
    "stacked-prs",
    "code-review",
    "ai",
    "cli"
  ],
  "author": "jzarecki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonzarecki/stacksmith.git"
  },
  "homepage": "https://github.com/jonzarecki/stacksmith",
  "bugs": {
    "url": "https://github.com/jonzarecki/stacksmith/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.105",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "cosmiconfig": "^9.0.0",
    "ora": "^9.3.0",
    "parse-diff": "^0.11.1",
    "simple-git": "^3.32.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
